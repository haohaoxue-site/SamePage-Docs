generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DocumentStatus {
  ACTIVE
  LOCKED
}

enum DocumentMemberRole {
  VIEWER
}

enum DocumentSpaceScope {
  PERSONAL
  TEAM
}

enum AuthProvider {
  GITHUB
  LINUX_DO
}

enum ChatSessionMessageRole {
  USER
  ASSISTANT
}

model User {
  id                 String             @id @default(uuid())
  email              String?            @unique
  displayName        String
  avatarUrl          String?
  status             UserStatus         @default(ACTIVE)
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  oauthAccounts      OauthAccount[]
  refreshTokens      AuthRefreshToken[]
  loginCodes         AuthLoginCode[]
  userRoles          UserRole[]
  ownedDocuments       Document[]      @relation("DocumentOwner")
  documentMemberships DocumentMember[]
  chatSessions         ChatSession[]
  adminAuditLogs       AdminAuditLog[] @relation("AdminAuditLogActor")
  updatedAiConfigs     SystemAiConfig[] @relation("SystemAiConfigUpdater")
}

model OauthAccount {
  id                    String       @id @default(uuid())
  userId                String
  provider              AuthProvider
  providerUserId        String
  providerUsername      String?
  providerEmail         String?
  providerEmailVerified Boolean?
  rawProfile            Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deletedAt             DateTime?
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model AuthOauthState {
  id           String       @id @default(uuid())
  provider     AuthProvider
  state        String       @unique
  codeVerifier String
  redirectUri  String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([provider, expiresAt])
}

model AuthRefreshToken {
  id           String            @id @default(uuid())
  userId        String
  tokenHash     String            @unique
  familyId      String
  replacedById  String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdIp     String?
  userAgent     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy    AuthRefreshToken? @relation("RefreshTokenRotation", fields: [replacedById], references: [id])
  rotatedFrom   AuthRefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model AuthLoginCode {
  id          String   @id @default(uuid())
  userId      String
  codeHash    String   @unique
  redirectUri String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Role {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Document {
  id         String             @id @default(uuid())
  ownerId    String
  parentId   String?
  spaceScope DocumentSpaceScope @default(PERSONAL)
  title      String
  content    String             @default("")
  summary    String             @default("")
  status     DocumentStatus     @default(ACTIVE)
  order      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?
  owner      User               @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  parent     Document?          @relation("DocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Document[]         @relation("DocumentTree")
  members    DocumentMember[]
  ydoc       DocumentYdoc?

  @@index([ownerId])
  @@index([parentId, order])
  @@index([spaceScope, status])
}

model DocumentMember {
  documentId String
  userId     String
  role       DocumentMemberRole
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([documentId, userId])
  @@index([userId])
  @@index([role])
}

model SystemAiConfig {
  id              String    @id @default(uuid())
  enabled         Boolean   @default(false)
  provider        String    @default("openai-compatible")
  baseUrl         String
  apiKey          String?
  defaultModel    String?
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  updatedByUser   User?     @relation("SystemAiConfigUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model ChatSession {
  id        String               @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  deletedAt DateTime?
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatSessionMessage[]

  @@index([userId, updatedAt])
}

model ChatSessionMessage {
  id        String                 @id @default(uuid())
  sessionId String
  role      ChatSessionMessageRole
  content   String
  order     Int
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  deletedAt DateTime?
  session   ChatSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, order])
  @@index([sessionId, createdAt])
}

model DocumentYdoc {
  documentId String   @id
  data       Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  actorUser   User     @relation("AdminAuditLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
}
