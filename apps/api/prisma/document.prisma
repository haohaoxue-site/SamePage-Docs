enum DocumentStatus {
  ACTIVE
  LOCKED
}

enum DocumentMemberRole {
  VIEWER
}

enum DocumentSpaceScope {
  PERSONAL
  TEAM
}

model Document {
  id               String             @id @default(uuid())
  ownerId          String
  parentId         String?
  spaceScope       DocumentSpaceScope @default(PERSONAL)
  title            String
  latestSnapshotId String?            @unique
  headRevision     Int                @default(0)
  summary          String             @default("")
  status           DocumentStatus     @default(ACTIVE)
  order            Int                @default(0)
  owner            User               @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  parent           Document?          @relation("DocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children         Document[]         @relation("DocumentTree")
  latestSnapshot   DocumentSnapshot?  @relation("DocumentLatestSnapshot", fields: [latestSnapshotId], references: [id], onDelete: SetNull)
  snapshots        DocumentSnapshot[] @relation("DocumentSnapshots")
  members          DocumentMember[]
  ydoc             DocumentYdoc?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  @@index([ownerId])
  @@index([parentId, order])
  @@index([spaceScope, status])
}

model DocumentSnapshot {
  id                String    @id @default(uuid())
  documentId        String
  revision          Int
  schemaVersion     Int
  title             Json
  body              Json
  source            String
  restoredFromSnapshotId String?
  document          Document  @relation("DocumentSnapshots", fields: [documentId], references: [id], onDelete: Cascade)
  latestForDocument Document? @relation("DocumentLatestSnapshot")
  createdAt         DateTime  @default(now())
  createdBy         String?
  createdByUser     User?     @relation("DocumentSnapshotCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  deletedAt         DateTime?

  @@unique([documentId, revision])
  @@index([documentId, createdAt])
}

model DocumentMember {
  documentId String
  userId     String
  role       DocumentMemberRole
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?

  @@id([documentId, userId])
  @@index([userId])
  @@index([role])
}

model DocumentYdoc {
  documentId String    @id
  data       Bytes
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
}
