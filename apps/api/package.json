{
  "name": "@haohaoxue/samepage-api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "dev:debug": "node --watch --inspect --import @swc-node/register/esm-register src/main.ts",
    "dev:prod": "node dist/main.js",
    "prebuild": "prisma generate",
    "build": "tsdown",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "type-check": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.spec.json --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^9.1.0",
    "@haohaoxue/samepage-contracts": "workspace:*",
    "@haohaoxue/samepage-domain": "workspace:*",
    "@haohaoxue/samepage-shared": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-fastify": "^11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.4",
    "jose": "^6.2.2",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^7.0.10",
    "openid-client": "^6.8.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.18",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.24",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "tsdown": "^0.21.7",
    "typescript": "catalog:"
  }
}
