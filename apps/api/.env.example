SERVER_PORT=3000
LOG_LEVEL=debug
LOG_PRETTY=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/samepage_docs

JWT_ISSUER=samepage-api
JWT_AUDIENCE=samepage-web
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN_SEC=900
JWT_REFRESH_EXPIRES_IN_SEC=2592000

AUTH_WEB_CALLBACK_LOCAL=http://localhost:5173/auth/callback
AUTH_API_BASE_URL_LOCAL=http://localhost:3000

SYSTEM_ADMIN_EMAILS=you@example.com

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_AUTHORIZATION_ENDPOINT=https://github.com/login/oauth/authorize
GITHUB_TOKEN_ENDPOINT=https://github.com/login/oauth/access_token
GITHUB_USERINFO_ENDPOINT=https://api.github.com/user
GITHUB_SCOPE=read:user user:email

LINUX_DO_CLIENT_ID=
LINUX_DO_CLIENT_SECRET=
LINUX_DO_AUTHORIZATION_ENDPOINT=
LINUX_DO_TOKEN_ENDPOINT=
LINUX_DO_USERINFO_ENDPOINT=
LINUX_DO_SCOPE=openid profile email
