{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "baseUrl": ".",
    "rootDir": "..",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@haohaoxue/samepage-domain": ["../domain/src/index.ts"]
    },
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
